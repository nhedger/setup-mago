{
	"name": "setup-mago",
	"description": "Setup the Mago CLI in GitHub Actions",
	"module": "src/index.ts",
	"type": "module",
	"scripts": {
		"tag": "bun run scripts/tag-github-action.ts",
		"build": "bun build . --outfile dist/index.mjs --target node --minify",
		"check": "biome check --write",
		"typecheck": "tsc --noEmit",
		"ci": "biome ci"
	},
	"keywords": [
		"mago",
		"php",
		"cli",
		"github-action"
	],
	"author": {
		"name": "Nicolas Hedger",
		"email": "nicolas@hedger.ch"
	},
	"license": "MIT",
	"dependencies": {
		"@actions/core": "3.0.1",
		"@actions/tool-cache": "4.0.0",
		"@octokit/auth-action": "6.0.2",
		"@octokit/request-error": "7.1.0",
		"@octokit/rest": "22.0.1",
		"semver": "7.8.5",
		"ts-dedent": "2.3.0",
		"yaml": "2.9.0"
	},
	"devDependencies": {
		"@biomejs/biome": "2.5.3",
		"@octokit/types": "16.0.0",
		"@types/bun": "1.3.14",
		"@types/semver": "7.7.1",
		"lefthook": "2.1.10",
		"typescript": "7.0.2"
	},
	"packageManager": "bun@1.1.4",
	"trustedDependencies": [
		"@biomejs/biome",
		"lefthook"
	]
}
